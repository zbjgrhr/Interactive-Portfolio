    },
    "prologue-4": {
      "en": "I build where intelligence, interaction and imagination meet."
    },
    "pixel-1": {
      "en": "An idea becomes a specification before it becomes an image."
    },
    "pixel-2": {
      "en": "Assets become rules; rules become movement."
    },
    "pixel-3": {
      "en": "A world is complete only when it can be entered, tested, and repaired."
    },
    "pixel-4": {
      "en": "Pixel World: from imagination to a game you can take with you."
    },
    "browser-1": {
      "en": "You cleared the noise."
    },
    "browser-2": {
      "en": "The useful signal was always there."
    },
    "browser-3": {
      "en": "I designed browser tools that turn repeated actions into intentional workflows."
    },
    "emotion-1": {
      "en": "Not every signal needs to be corrected."
    },
    "emotion-2": {
      "en": "Some need to be heard."
    },
    "emotion-3": {
      "en": "A thoughtful system knows when to respond — and when to leave space."
    },
    "research-1": {
      "en": "Raw signals rarely explain themselves."
    },
    "research-2": {
      "en": "Patterns emerge through careful questions."
    },
    "research-3": {
      "en": "Research taught me to look beyond the visible interface."
    },
    "coda-1": {
