  "projects": [
    {
      "id": "pixel-seed",
      "title": "Pixel World",
      "oneLiner": "One idea becomes an editable game specification, a controllable asset system, and a playable world that can ship.",
      "context": "Pixel World carries an idea through GameSpec V3, asset planning, generation, review, level assignment, runtime assembly, playtesting, and offline export.",
      "problem": "Free-form imagination has to become dozens of coordinated, runtime-safe decisions without taking creative control away from the maker.",
      "role": "Independent product ownership and full-stack implementation across research, product architecture, generation pipelines, interaction design, game runtime, persistence, and deployment.",
      "process": [
        "Translate a free-form idea into GameSpec V3",
        "Expand the specification into 38 editable asset categories",
        "Generate and review assets plus seven independent character actions",
        "Validate the result in a five-level playable runtime",
        "Export the finished world as a complete offline game"
      ],
      "keyDecisions": [
        "Make the specification inspectable before generation begins",
        "Keep every generation task modular, recoverable, and editable",
        "Use playability and export as the final proof of quality"
      ],
      "technology": [
        "Next.js 15",
        "React 19",
        "TypeScript",
        "Ant Design",
        "Zustand",
        "Seedream 4.5",
        "FLUX.2 Pro",
        "IndexedDB",
        "Web Audio",
        "Custom 2D runtime"
      ],
      "challenges": [
        "Keeping 38 asset categories coherent and runtime-safe",
        "Mapping expressive prompts into structured rules",
        "Recovering from partial generation and persistence failures"
      ],
      "outcome": "A live V3 product that turns one idea into a reviewable asset system and a five-level game, then exports the finished world as an offline package.",
      "learned": [
        "Creative AI becomes a product when uncertain steps can be inspected, corrected, and resumed",
        "A world is complete only when it survives play, persistence, and delivery"
      ],
      "coverSrc": "/portfolio/pixel-world-gameplay.png",
      "gallery": [
        "/portfolio/pixel-world-gameplay.png",
        "/portfolio/pixel-world-spec.png",
        "/portfolio/pixel-world-assets.png",
        "/portfolio/pixel-world-actions.png",
        "/portfolio/pixel-world-water.png"
      ],
      "github": "https://github.com/zbjgrhr/PIXEL-WORLD",
      "liveDemo": "https://pixel-world-silk.vercel.app/",
      "category": "AI Product · Game Systems",
      "period": "2024–2026 · Independent product",
      "status": "V3 · Live product",
      "featured": true,
