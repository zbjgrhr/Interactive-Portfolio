  "projects": [
    {
      "id": "pixel-seed",
      "title": "Pixel Seed",
      "oneLiner": "An AI platform that turns a prompt into a playable pixel world.",
      "context": "Players wanted game creation without art pipelines. Pixel Seed closes the gap between imagination and a runnable 2D stage.",
      "problem": "Generating assets is easy; loading them into coherent, playable platformer logic is not.",
      "role": "Product design, frontend, game logic, generation flow, and deployment.",
      "process": [
        "Prompt intake and theme framing",
        "AI pixel character and background generation",
        "Asset packaging into a Phaser-ready stage",
        "Playable preview and iteration loop"
      ],
      "keyDecisions": [
        "Treat generation as a pipeline, not a single API call",
        "Keep the playable loop first-class so output is never only an image",
        "Ship with Next.js + TypeScript for product and game unity"
      ],
      "technology": [
        "Next.js",
        "TypeScript",
        "AI image generation",
        "2D platformer runtime"
      ],
      "challenges": [
        "Inconsistent asset dimensions and palettes",
        "Mapping freeform prompts into constrained game templates",
        "Keeping generation latency tolerable for interactive use"
      ],
      "outcome": "A working platform where a theme becomes sprites, a stage, and a short playable session.",
      "learned": [
        "Creative AI products need strong constraints to feel intentional",
        "Playability is the proof, not the render"
      ],
      "coverSrc": "/portfolio/pixel-seed-hero.webp",
      "gallery": [
        "/portfolio/pixel-seed-hero.webp"
      ]
    },
    {
      "id": "browser-tools",
      "title": "Browser Extension Tools",
      "oneLiner": "Turning repeated web actions into intentional workflows.",
      "context": "Browser work often means noise: duplicated tabs, scattered copy, and manual cleanup.",
      "problem": "Useful signals hide inside repetitive page patterns that tools rarely restructure.",
      "role": "Interaction design and extension tooling for extraction, folding, and automation paths.",
      "process": [
        "Observe repeated user friction on the page",
        "Design activation points that feel like clearing noise",
        "Extract structured signal from cluttered DOM",
        "Open automation paths without hijacking the browser"
      ],
      "keyDecisions": [
        "Prefer visible, reversible transformations over silent scripts",
        "Model workflows as sequences the user can understand"
      ],
      "technology": [
        "Browser extensions",
        "DOM automation",
        "TypeScript"
      ],
      "challenges": [
        "Fragile page structures across sites",
        "Permission and trust boundaries"
      ],
      "outcome": "Tools that collapse noise and surface the useful signal.",
      "learned": [
        "Efficiency is a design problem before it is a scraping problem"
      ],
      "coverSrc": "/portfolio/web-study-workspace.webp",
      "gallery": [
        "/portfolio/web-study-workspace.webp"
      ]
    },
    {
      "id": "emotion-chatbot",
      "title": "Emotion-Cognitive Chatbot",
      "oneLiner": "A dialogue system that knows when to respond — and when to leave space.",
      "context": "Supportive conversation products often over-correct emotion instead of holding it.",
      "problem": "Emotion is not a bug to fix. Systems need context, boundaries, and safety — not only model calls.",
      "role": "Conversation UX, cognitive framing, and product boundary design.",
      "process": [
        "Map emotional paths without scoring them as wins/losses",
        "Design response timing and silence as first-class behaviors",
        "Define safety rails and escalation edges"
      ],
      "keyDecisions": [
        "Do not gamify negative emotion as something to defeat",
        "Treat listening as an interaction mode"
      ],
      "technology": [
        "Conversational AI",
        "Product UX",
        "Safety guidelines"
      ],
      "challenges": [
        "Avoiding false certainty in emotional interpretation",
        "Keeping warmth without over-promising clinical care"
      ],
      "outcome": "A calmer dialogue surface oriented around presence and boundaries.",
      "learned": [
        "Not every signal needs to be corrected",
        "Thoughtful systems leave space"
      ],
      "coverSrc": "/portfolio/innerseed-hero.webp",
      "gallery": [
        "/portfolio/innerseed-hero.webp"
      ]
    },
    {
      "id": "multimodal-research",
      "title": "Multimodal AI Research",
      "oneLiner": "EEG + eye-tracking signals turned into interpretable structure.",
      "context": "At Lanzhou University, multimodal research required careful handling of noisy biological signals.",
      "problem": "Raw signals rarely explain themselves without disciplined questions.",
      "role": "Data cleaning, feature extraction and selection, tree-model training and tuning, evaluation, visualization, and paper discussion.",
      "process": [
        "Data organization and cleaning",
        "Feature extraction and selection",
        "Tree model training and parameter tuning",
        "Evaluation and visualization",
        "Literature reading and research discussion"
      ],
      "keyDecisions": [
        "Prioritize interpretable features before model complexity",
        "Treat evaluation as a narrative of what the signal can claim"
      ],
      "technology": [
        "EEG",
        "Eye-tracking",
        "Feature engineering",
        "Tree models"
      ],
      "challenges": [
        "Noise and alignment across modalities",
        "Avoiding overfit stories about weak signals"
      ],
      "outcome": "A research practice of moving from chaos to explainable structure.",
      "learned": [
        "Patterns emerge through careful questions",
        "Look beyond the visible interface"
      ],
      "coverSrc": "/portfolio/eeg-processing.webp",
      "gallery": [
        "/portfolio/eeg-processing.webp"
      ]
    }
  ],
